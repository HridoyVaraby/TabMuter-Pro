{
  "manifest_version": 3,
  "name": "TabMuter Pro",
  "version": "1.0.0",
  "description": "Automatically and persistently mute audio from selected websites, domains, and Chrome tabs.",
  "permissions": ["storage", "tabs"],
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "TabMuter Pro",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png"
    }
  }
}
